---
import { Image } from "astro:assets";
import Services from "./Services.astro";
import CEOImage from "@assets/images/ceo.webp";
import ArrowRight from "@icons/arrow--right.svg";
---

<section class="hero">
  <div class="hero-content">
    <h1>Empowering Your Business Growth</h1>
    <p>
      Discover tailored strategies and expert insights to take your business to
      the next level. Let us help you navigate challenges and achieve
      sustainable success.
    </p>
    <a href="#0">Book a Meeting</a>
    <a href="#0">Learn More <ArrowRight stroke-width={2.5} /></a>
  </div>
  <Image src={CEOImage} alt="CEO" />
  <div class="services">
    <Services />
  </div>
</section>

<style>
  /* Styles her */
  @layer components {
    .hero {
      container-type: inline-size;
      background-color: var(--color-ui-primary);

      display: grid;
      gap: var(--space-m);

      & img {
        display: none;
      }
    }

    .hero-content {
      padding: 2rem;

      & > * + * {
        margin-top: var(--space-s, 1rlh);
      }
    }

    @media (min-width: 600px) {
      .hero {
        grid-template-columns: 1fr minmax(0, 500px) minmax(0, 500px) 1fr;
        grid-template-rows: auto 1fr 1fr;
        align-items: center;
        width: 100%;
      }

      .hero-content {
        grid-column: 2/3;
        grid-row: 1/2;
      }

      img {
        grid-column: 3/5;
        grid-row: 1/3;
        object-fit: cover;
        align-self: stretch;
        overflow: hidden;
        width: 100%;
        height: auto;
      }

      .services {
        grid-column: 2/4;
        grid-row: 2/4;
      }

      .hero img {
        display: block;
      }
    }

    .hero-content {
      & h1 {
        color: var(--color-on-ui-primary);
        font-size: var(--step-4);
        font-weight: bold;
        width: 15ch;
      }

      & p {
        color: var(--color-on-ui-primary-muted);
        font-size: var(--step-1);
      }
      a {
        border-radius: var(--border-radius-xl);
        padding-block: 12px;
        padding-inline: 18px;
        background-color: var(--color-ui-primary);
        color: var(--color-on-ui-primary);
        text-decoration: none;
        outline: 1px solid var(--color-on-ui-primary-muted);
        display: inline-flex;
        gap: 1ch;
        font-size: var(--step-1);
        font-weight: 500;

        svg {
          inline-size: 16px;
          color: var(--color-on-ui-primary);
        }

        &:not(:last-child) {
          background-color: var(--color-action);
          color: var(--color-text);
          outline: none;
        }
      }
    }
  }
</style>
